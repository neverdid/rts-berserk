{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Ashen Dominion development",
      "binaryDir": "${sourceDir}/build/native",
      "cacheVariables": {
        "ASHEN_BUILD_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Ashen Dominion release",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "ASHEN_BUILD_TESTS": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
